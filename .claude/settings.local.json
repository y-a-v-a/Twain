{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift package:*)",
      "Bash(./build.sh:*)",
      "Bash(./run.sh:*)",
      "Bash(./release.sh:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:swiftpackageindex.com)",
      "WebSearch",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ]
  }
}
